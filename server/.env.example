# ───────────────────────────────────────────────
# Coastal Innovation Summit — Environment Config
# Copy this file to .env and fill in real values
# ───────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# JWT (min 16 characters each)
JWT_SECRET=change-me-to-a-strong-random-string
JWT_REFRESH_SECRET=change-me-to-another-strong-random-string

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Google Sheets
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id

# Brevo (email)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Coastal Innovation Summit

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
